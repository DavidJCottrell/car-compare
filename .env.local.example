# Vercel Postgres — these are set automatically when you link a Postgres database
# in the Vercel dashboard. Copy this file to .env.local for local development.
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Anthropic API — required for the AI depreciation estimator
# Get your key from: https://console.anthropic.com
# Add this to Vercel: Project Settings → Environment Variables
ANTHROPIC_API_KEY=
